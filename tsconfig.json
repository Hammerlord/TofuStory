{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "skipLibCheck": true,

    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src", "scripts", "*.d.ts"],
  "exclude": ["node_modules", "**/*.spec.ts", "**/*.test.ts"]
}